<Window x:Class="PhonePadBridge.WebBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhonePad Bridge — Hyperdrive"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#050814">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.18,0.08" GradientOrigin="0.18,0.08" RadiusX="1.15" RadiusY="1.15">
                <GradientStop Color="#173A5A" Offset="0"/>
                <GradientStop Color="#0A1024" Offset="0.42"/>
                <GradientStop Color="#050814" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False" Opacity="0.45">
            <Ellipse Width="380" Height="380" Canvas.Left="-110" Canvas.Top="-130" Stroke="#2637D7FF" StrokeThickness="2"/>
            <Ellipse Width="250" Height="250" Canvas.Left="930" Canvas.Top="-80" Stroke="#309A5CFF" StrokeThickness="2"/>
            <Ellipse Width="470" Height="470" Canvas.Left="820" Canvas.Top="500" Stroke="#18FF4DA6" StrokeThickness="2"/>
            <Line X1="0" Y1="100" X2="1260" Y2="20" Stroke="#1037D7FF" StrokeThickness="1"/>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0"
                        CornerRadius="28"
                        Padding="18"
                        BorderBrush="#2B4169"
                        BorderThickness="1"
                        Effect="{StaticResource PanelShadow}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#151F35" Offset="0"/>
                            <GradientStop Color="#0A1020" Offset="0.58"/>
                            <GradientStop Color="#09111F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top">
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="40" Height="40" CornerRadius="14" Effect="{StaticResource CyanGlow}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#37D7FF" Offset="0"/>
                                            <GradientStop Color="#9A5CFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="PB" Foreground="White" FontWeight="Black" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PhonePad" Foreground="White" FontSize="26" FontWeight="Black"/>
                                    <TextBlock Text="HYPERDRIVE BRIDGE" Foreground="#37D7FF" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Border CornerRadius="18" Padding="12" Margin="0,0,0,10" BorderBrush="#263D65" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#12223B" Offset="0"/>
                                        <GradientStop Color="#07101F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="13" Height="13" Fill="#37D7FF" Effect="{StaticResource CyanGlow}" VerticalAlignment="Top" Margin="0,5,0,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="WEB SERVER" Foreground="#91A0BE" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="ServerStatusText"
                                                   Text="Stopped"
                                                   Foreground="White"
                                                   FontSize="15"
                                                   FontWeight="Black"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border CornerRadius="18" Padding="12" Margin="0,0,0,14" BorderBrush="#263D65" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#12223B" Offset="0"/>
                                        <GradientStop Color="#07101F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="13" Height="13" Fill="#48F2A5" VerticalAlignment="Top" Margin="0,5,0,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.75" Color="#48F2A5"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="VIRTUAL XBOX" Foreground="#91A0BE" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="VirtualStatusText"
                                                   Text="Not started"
                                                   Foreground="White"
                                                   FontSize="15"
                                                   FontWeight="Black"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Button x:Name="StartButton"
                                    Content="▶ Start Bridge"
                                    Margin="0,0,0,8"
                                    Padding="10,8"
                                    Click="StartButton_Click"/>

                            <Button x:Name="AndroidUsbButton"
                                    Content="◆ Android USB Setup"
                                    Margin="0,0,0,8"
                                    Padding="10,8"
                                    Click="AndroidUsbButton_Click"
                                    Style="{StaticResource GreenButton}"/>

                            <Button x:Name="StopButton"
                                    Content="■ Stop Bridge"
                                    Margin="0,0,0,14"
                                    Padding="10,8"
                                    Click="StopButton_Click"
                                    Style="{StaticResource DangerButton}"/>

                            <TextBlock Text="PORT" Foreground="#91A0BE" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PortBox" Text="49494" FontSize="14" Margin="0,0,0,12" Padding="9"/>

                            <TextBlock Text="THEME ACCENT" Foreground="#91A0BE" FontSize="10" FontWeight="Bold" Margin="0,0,0,7"/>
                            <WrapPanel>
                                <Button Content="Cyan" Tag="#37D7FF" Click="Accent_Click" Margin="0,0,6,6" Padding="8,5" FontSize="11"/>
                                <Button Content="Blue" Tag="#5A8CFF" Click="Accent_Click" Margin="0,0,6,6" Padding="8,5" FontSize="11"/>
                                <Button Content="Pink" Tag="#FF4DA6" Click="Accent_Click" Margin="0,0,6,6" Padding="8,5" FontSize="11"/>
                                <Button Content="Green" Tag="#48F2A5" Click="Accent_Click" Margin="0,0,6,6" Padding="8,5" FontSize="11"/>
                                <Button Content="Gold" Tag="#FFB347" Click="Accent_Click" Margin="0,0,6,6" Padding="8,5" FontSize="11"/>
                            </WrapPanel>
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom"
                                CornerRadius="20"
                                Padding="13"
                                BorderBrush="#23385F"
                                BorderThickness="1"
                                Margin="0,14,0,0"
                                MinHeight="130">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0C172A" Offset="0"/>
                                    <GradientStop Color="#080E1B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="INPUT PIPELINE" Foreground="#91A0BE" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="Controller → Phone" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="↓ ADB/WebSocket" Foreground="#37D7FF" FontWeight="Bold" Margin="0,3,0,3" FontSize="12"/>
                                <TextBlock Text="Virtual Xbox → Game" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Main content -->
                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="140"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top command center -->
                    <Border Grid.Row="0"
                            CornerRadius="28"
                            Padding="18"
                            BorderBrush="#2B4169"
                            BorderThickness="1"
                            Effect="{StaticResource PanelShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#151F35" Offset="0"/>
                                <GradientStop Color="#0A1122" Offset="0.68"/>
                                <GradientStop Color="#0E1730" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="210"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Command Center" Foreground="White" FontSize="25" FontWeight="Black"/>
                                <TextBlock Text="Open the bridge URL on your phone. Android USB mode uses 127.0.0.1 after the ADB setup button."
                                           Foreground="#91A0BE"
                                           FontSize="12"
                                           Margin="0,5,0,8"
                                           TextWrapping="Wrap"/>

                                <Border CornerRadius="16" Padding="12" BorderBrush="#23436A" BorderThickness="1" Background="#07101F" MaxHeight="58">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="UrlText"
                                                   Text="Start the bridge to show URLs."
                                                   Foreground="#37D7FF"
                                                   FontSize="13"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" CornerRadius="18" Padding="12" Margin="0,0,0,6" BorderBrush="#2A4169" BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#101E35" Offset="0"/>
                                            <GradientStop Color="#08111F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="LAST PACKET" Foreground="#91A0BE" FontSize="9" FontWeight="Bold"/>
                                        <TextBlock x:Name="PacketText" Text="—" Foreground="White" FontSize="19" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" CornerRadius="18" Padding="12" Margin="0,6,0,0" BorderBrush="#2A4169" BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#101E35" Offset="0"/>
                                            <GradientStop Color="#08111F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="GAMEPAD" Foreground="#91A0BE" FontSize="9" FontWeight="Bold"/>
                                        <TextBlock x:Name="GamepadText"
                                                   Text="No gamepad yet"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="32"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*"/>
                            <ColumnDefinition Width="0.88*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Input visualizer -->
                        <Border Grid.Column="0"
                                CornerRadius="28"
                                Padding="18"
                                BorderBrush="#2B4169"
                                BorderThickness="1"
                                Effect="{StaticResource PanelShadow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#121C31" Offset="0"/>
                                    <GradientStop Color="#08101F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="215"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Live Input Telemetry" Foreground="White" FontSize="23" FontWeight="Black"/>
                                        <TextBlock Text="Low-latency controller feed. UI stays light so input stays fast."
                                                   Foreground="#91A0BE"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="13" Padding="10,6" Background="#12304A" BorderBrush="#37D7FF" BorderThickness="1">
                                        <TextBlock Text="120 Hz Ready" Foreground="#BFF5FF" FontWeight="Bold" FontSize="11"/>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="23" Padding="12" Margin="0,0,8,0" BorderBrush="#253D63" BorderThickness="1" Background="#07101F">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="LEFT STICK" Foreground="#91A0BE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <Canvas Width="168" Height="168" Margin="0,7,0,0">
                                                <Ellipse Width="168" Height="168" Stroke="#304A73" StrokeThickness="2"/>
                                                <Ellipse Width="104" Height="104" Canvas.Left="32" Canvas.Top="32" Stroke="#1737D7FF" StrokeThickness="1"/>
                                                <Line X1="84" Y1="0" X2="84" Y2="168" Stroke="#1837D7FF" StrokeThickness="1"/>
                                                <Line X1="0" Y1="84" X2="168" Y2="84" Stroke="#1837D7FF" StrokeThickness="1"/>
                                                <Ellipse x:Name="LeftStickDot" Width="18" Height="18" Fill="#37D7FF" Canvas.Left="75" Canvas.Top="75" Effect="{StaticResource CyanGlow}"/>
                                            </Canvas>
                                            <TextBlock x:Name="LeftStickText" Text="0.00, 0.00" Foreground="#91A0BE" FontFamily="Consolas" HorizontalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="23" Padding="12" Margin="8,0,0,0" BorderBrush="#253D63" BorderThickness="1" Background="#07101F">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="RIGHT STICK" Foreground="#91A0BE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <Canvas Width="168" Height="168" Margin="0,7,0,0">
                                                <Ellipse Width="168" Height="168" Stroke="#304A73" StrokeThickness="2"/>
                                                <Ellipse Width="104" Height="104" Canvas.Left="32" Canvas.Top="32" Stroke="#1737D7FF" StrokeThickness="1"/>
                                                <Line X1="84" Y1="0" X2="84" Y2="168" Stroke="#1837D7FF" StrokeThickness="1"/>
                                                <Line X1="0" Y1="84" X2="168" Y2="84" Stroke="#1837D7FF" StrokeThickness="1"/>
                                                <Ellipse x:Name="RightStickDot" Width="18" Height="18" Fill="#37D7FF" Canvas.Left="75" Canvas.Top="75" Effect="{StaticResource CyanGlow}"/>
                                            </Canvas>
                                            <TextBlock x:Name="RightStickText" Text="0.00, 0.00" Foreground="#91A0BE" FontFamily="Consolas" HorizontalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="18" Padding="11" Margin="0,0,8,0" Background="#07101F" BorderBrush="#253D63" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="LEFT TRIGGER" Foreground="#91A0BE" FontSize="10" FontWeight="Bold"/>
                                            <ProgressBar x:Name="LtBar" Minimum="0" Maximum="100" Margin="0,7,0,0" Height="14"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" CornerRadius="18" Padding="11" Margin="8,0,0,0" Background="#07101F" BorderBrush="#253D63" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="RIGHT TRIGGER" Foreground="#91A0BE" FontSize="10" FontWeight="Bold"/>
                                            <ProgressBar x:Name="RtBar" Minimum="0" Maximum="100" Margin="0,7,0,0" Height="14"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid x:Name="ButtonsPanel"
                                             Grid.Row="3"
                                             Columns="7"
                                             Margin="0,16,0,0"
                                             Height="100"/>
                            </Grid>
                        </Border>

                        <!-- Log panel -->
                        <Border Grid.Column="1"
                                CornerRadius="28"
                                Padding="18"
                                BorderBrush="#2B4169"
                                BorderThickness="1"
                                Margin="16,0,0,0"
                                Effect="{StaticResource PanelShadow}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#121C31" Offset="0"/>
                                    <GradientStop Color="#07101F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="System Console" Foreground="White" FontSize="23" FontWeight="Black"/>
                                    <TextBlock Text="Bridge events, driver status, ADB output, and errors."
                                               Foreground="#91A0BE"
                                               FontSize="11"
                                               Margin="0,4,0,14"/>
                                </StackPanel>

                                <Border Grid.Row="1" CornerRadius="22" Padding="14" Background="#040811" BorderBrush="#20375C" BorderThickness="1" MinHeight="430">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="LogText"
                                                   Foreground="#B8C9EA"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
